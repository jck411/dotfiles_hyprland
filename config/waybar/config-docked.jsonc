{
	"layer": "top",
	"position": "top",
	"height": 38,
	"margin": "0",
	"spacing": 8,
	"start_hidden": true,
	"on-sigusr1": "show",
	"on-sigusr2": "hide",
	"modules-left": [
		"hyprland/workspaces",
		"hyprland/window"
	],
	"modules-center": [
		"clock"
	],
	"modules-right": [
		"custom/openrouter",
		"custom/bookmarks",
		"custom/obsidian",
		"pulseaudio",
		"network",
		"bluetooth",
		"custom/power-profile",
		"battery",
		"tray",
		"custom/power"
	],
	"hyprland/workspaces": {
		"format": "{id}",
		"on-click": "activate",
		"all-outputs": true,
		"active-only": false
	},
	"hyprland/window": {
		"format": "{}",
		"max-length": 50,
		"separate-outputs": true,
		"on-click": "pkill rofi"
	},
	"clock": {
		"interval": 60,
		"format": "{:%H:%M}",
		"format-alt": "{:%A, %B %d, %Y (%H:%M)}",
		"tooltip-format": "<tt><small>{calendar}</small></tt>",
		"calendar": {
			"mode": "month",
			"format": {
				"months": "<span color='#88C0D0'><b>{}</b></span>",
				"days": "<span color='#D8DEE9'>{}</span>",
				"weekdays": "<span color='#81A1C1'><b>{}</b></span>",
				"today": "<span color='#BF616A'><b><u>{}</u></b></span>"
			}
		}
	},
	"pulseaudio": {
		"format": "{icon} {volume}%",
		"format-muted": "蟀潫 {volume}%",
		"format-icons": {
			"default": [
				"蟀暱",
				"蟀杸",
				"蟀暰"
			]
		},
		"on-click": "~/.config/waybar/volume-popup.sh",
		"on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
		"scroll-step": 5,
		"tooltip-format": "{desc}"
	},
	"network": {
		"format-wifi": "蟀え {signalStrength}%",
		"format-ethernet": "蟀垁 Connected",
		"format-disconnected": "蟀き",
		"tooltip-format": "{essid} ({signalStrength}%)\n{ipaddr}",
		"tooltip-format-ethernet": "{ifname}: {ipaddr}",
		"on-click": "~/.config/waybar/wifi-menu.sh"
	},
	"bluetooth": {
		"format": "蟀偗",
		"format-connected": "蟀偙 {num_connections}",
		"format-disabled": "蟀偛",
		"format-off": "蟀偛",
		"tooltip-format": "{controller_alias}\n{status}",
		"tooltip-format-connected": "{controller_alias}\n{num_connections} connected\n\n{device_enumerate}",
		"tooltip-format-enumerate-connected": "{device_alias}",
		"tooltip-format-enumerate-connected-battery": "{device_alias} ({device_battery_percentage}%)",
		"on-click": "~/.config/waybar/bluetooth-menu.sh"
	},
	"battery": {
		"bat": "BAT0",
		"interval": 60,
		"states": {
			"warning": 30,
			"critical": 15
		},
		"format": "{icon} {capacity}%",
		"format-charging": "蟀倓 {capacity}%",
		"format-plugged": "蟀倓 {capacity}%",
		"format-full": "蟀伖 {capacity}%",
		"format-icons": [
			"蟀伜",
			"蟀伝",
			"蟀伡",
			"蟀伣",
			"蟀伨",
			"蟀伩",
			"蟀個",
			"蟀倎",
			"蟀倐",
			"蟀伖"
		],
		"tooltip-format": "{timeTo}\n{power} W",
		"on-click": "~/.config/waybar/battery-settings.sh"
	},
	"custom/power-profile": {
		"exec": "powerprofilesctl get",
		"interval": 30,
		"format": "蟀垚 {}",
		"tooltip": true,
		"tooltip-format": "Power Profile: {}",
		"on-click": "~/.config/waybar/power-menu.sh"
	},
	"tray": {
		"icon-size": 18,
		"spacing": 8
	},
	"custom/power": {
		"format": "蟀惀",
		"tooltip": true,
		"tooltip-format": "Power Menu",
		"on-click": "~/.config/waybar/power-actions.sh"
	},
	"custom/bookmarks": {
		"format": "蟀儉",
		"tooltip": true,
		"tooltip-format": "Web Apps",
		"on-click": "~/.config/waybar/bookmarks-menu.sh"
	},
	"custom/obsidian": {
		"format": "鉁忥笍",
		"tooltip": true,
		"tooltip-format": "New Obsidian Note",
		"on-click": "~/.config/waybar/obsidian-note.sh"
	},
	"custom/openrouter": {
		"exec": "~/.config/waybar/openrouter.sh",
		"return-type": "json",
		"interval": "once",
		"signal": 9,
		"on-click": "pkill -RTMIN+9 waybar",
		"on-click-right": "brave --app=https://openrouter.ai/logs --remote-debugging-port=9222 --force-dark-mode --disable-session-restore &"
	}
}
